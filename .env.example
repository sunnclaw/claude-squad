# Claude天团 Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# Email Provider Configuration (REQUIRED for outreach)
# ============================================
# Get your API key from: https://resend.com/api-keys
# Free tier: 3,000 emails/month
RESEND_API_KEY=re_your_api_key_here

# Sender email address (must be verified in Resend)
EMAIL_FROM=Claude天团 <outreach@claude-squad.com>

# ============================================
# Alternative: SendGrid (optional)
# ============================================
# SENDGRID_API_KEY=SG.your_sendgrid_key_here

# ============================================
# Alternative: Gmail SMTP (for testing only)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ============================================
# Setup Instructions
# ============================================
# 1. Sign up for Resend at https://resend.com (5 minutes)
# 2. Go to Dashboard > API Keys
# 3. Create a new API key named "claude-squad-outreach"
# 4. Copy the key (starts with "re_")
# 5. Create .env file: cp .env.example .env
# 6. Paste your key in the .env file
# 7. Test: node marketing/email-sender.js --list-ready
